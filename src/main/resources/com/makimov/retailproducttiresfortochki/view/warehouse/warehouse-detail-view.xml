<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://warehouseDetailView.title"
      focusComponent="form">
    <data>
        <instance id="warehouseDc"
                  class="com.makimov.retailproducttiresfortochki.entity.Warehouse">
            <fetchPlan extends="_base"/>
            <loader id="warehouseDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="warehouseDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="idField" property="id"/>
            <textField id="keyField" property="key"/>
            <textField id="nameField" property="name"/>
            <textField id="daysField" property="days"/>
            <textField id="deliveryDaysAdditionalField" property="deliveryDaysAdditional"/>
            <checkbox id="getStocksField" property="getStocks"/>
            <checkbox id="uploadToSiteField" property="uploadToSite"/>
            <checkbox id="prepayField" property="prepay"/>
            <checkbox id="deliveryOnlyToTerminalField" property="deliveryOnlyToTerminal"/>
            <textField id="deliveryDaysTotalField" property="deliveryDaysTotal"/>
            <dateTimePicker id="dateUpdateField" property="dateUpdate"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
