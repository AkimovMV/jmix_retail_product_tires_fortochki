<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://warehouseListView.title"
      focusComponent="warehousesDataGrid">
    <data>
        <collection id="warehousesDc"
                    class="com.makimov.retailproducttiresfortochki.entity.Warehouse">
            <fetchPlan extends="_base"/>
            <loader id="warehousesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Warehouse e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="warehousesDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="loadingWarehouses" text="msg://loadingWarehouses1.text"/>
            <startSlot>
                <button id="createButton" action="warehousesDataGrid.createAction"/>
                <button id="editButton" action="warehousesDataGrid.editAction"/>
                <button id="refreshButton" action="warehousesDataGrid.refreshAction"/>
                <button id="removeButton" action="warehousesDataGrid.removeAction"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="warehousesDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="warehousesDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="warehousesDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="refreshAction" type="list_refresh"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="id"/>
                <column property="key"/>
                <column property="name"/>
                <column property="days"/>
                <column property="getStocks"/>
                <column property="dateUpdate"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
