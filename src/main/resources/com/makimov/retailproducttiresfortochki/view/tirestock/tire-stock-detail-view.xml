<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://tireStockDetailView.title"
      focusComponent="form">
    <data>
        <instance id="tireStockDc"
                  class="com.makimov.retailproducttiresfortochki.entity.TireStock">
            <fetchPlan extends="_base">
                <property name="warehouse" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="tireStockDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="tireStockDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <entityPicker id="warehouseField" property="warehouse">
                <actions>
                    <action id="entityLookupAction" type="entity_lookup"/>
                    <action id="entityClearAction" type="entity_clear"/>
                </actions>
            </entityPicker>
            <textField id="producerArticleIdField" property="producerArticleId"/>
            <textField id="producerField" property="producer"/>
            <textField id="countField" property="count"/>
            <textField id="priceField" property="price"/>
            <textField id="price_retailField" property="price_retail"/>
            <dateTimePicker id="dateUpdateField" property="dateUpdate"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
